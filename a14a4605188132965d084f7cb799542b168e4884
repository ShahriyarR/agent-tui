xception as e:\n            logger.exception(\"Sandbox write error\")\n            return {\"error\": f\"Failed to write '{file_path}': {str(e)}\"}\n    \n    async def edit(\n        self,\n        file_path: str,\n        old_string: str,\n        new_string: str,\n    ) -> EditResult:\n        \"\"\"Edit file in sandbox.\"\"\"\n        try:\n            target = self._resolve_path(file_path)\n            \n            if not target.exists():\n                return {\"error\": f\"File '{file_path}' not found\"}\n            \n            content = target.read_text()\n            \n            if old_string not in content:\n                return {\"error\": f\"Old string not found in '{file_path}'\"}\n            \n            new_content = content.replace(old_string, new_string, 1)\n            target.write_text(new_content)\n            \n            return {\n                \"file_path\": file_path,\n                \"replacement_count\": 1,\n            }\n        except ValueError as e:\n            return {\"error\": str(e)}\n        except Exception as e:\n            logger.exception(\"Sandbox edit error\")\n            return {\"error\": f\"Failed to edit '{file_path}': {str(e)}\"}\n    \n    async def ls(\n        self,\n        path: str = \".\",\n    ) -> LsResult:\n        \"\"\"List directory in sandbox.\"\"\"\n        try:\n            target = self._resolve_path(path)\n            \n            if not target.exists():\n                return {\"error\": f\"Directory '{path}' not found\"}\n            \n            if not target.is_dir():\n                return {\"error\": f\"'{path}' is not a directory\"}\n            \n            entries = []\n            for entry in target.iterdir():\n                stat = entry.stat()\n                entries.append({\n                    \"name\": entry.name,\n                    \"type\": \"directory\" if entry.is_dir() else \"file\",\n                    \"size\": stat.st_size if entry.is_file() else None,\n                })\n            \n            return {\n                \"path\": path,\n                \"entries\": entries,\n            }\n        except ValueError as e:\n            return {\"error\": str(e)}\n        except Exception as e:\n            logger.exception(\"Sandbox ls error\")\n            return {\"error\": f\"Failed to list '{path}': {str(e)}\"}\n    \n    async def glob(\n        self,\n        pattern: str,\n    ) -> GlobResult:\n        \"\"\"Search files in sandbox using glob pattern.\"\"\"\n        try:\n            # Ensure pattern is relative\n            if pattern.startswith(\"/\"):\n                pattern = pattern[1:]\n            \n            matches = list(self.root_dir.glob(pattern))\n            \n            files = []\n            for match in matches:\n                if match.is_file():\n                    # Get relative path from sandbox root\n                    rel_path = match.relative_to(self.root_dir)\n                    files.append(str(rel_path))\n            \n            return {\n                \"pattern\": pattern,\n                \"files\": files,\n                \"match_count\": len(files),\n            }\n        except Exception as e:\n            logger.exception(\"Sandbox glob error\")\n            return {\"error\": f\"Failed to glob '{pattern}': {str(e)}\"}\n    \n    async def grep(\n        self,\n        pattern: str,\n        path: str,\n    ) -> GrepResult:\n        \"\"\"Search content in sandbox files.\"\"\"\n        try:\n            import re\n            \n            target = self._resolve_path(path)\n            \n            if not target.exists():\n                return {\"error\": f\"Path '{path}' not found\"}\n            \n            matches = []\n            \n            if target.is_file():\n                files_to_search = [target]\n            else:\n                # Search all files in directory recursively\n                files_to_search = [f for f in target.rglob(