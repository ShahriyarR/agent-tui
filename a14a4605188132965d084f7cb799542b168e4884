r.decode(\"utf-8\", errors=\"replace\"),\n                \"exit_code\": proc.returncode,\n            }\n        except asyncio.TimeoutError:\n            proc.kill()\n            return {\"error\": f\"Command timed out after {timeout or 60.0}s\"}\n        except Exception as e:\n            logger.exception(\"Sandbox execute error\")\n            return {\"error\": f\"Failed to execute command: {str(e)}\"}\n    \n    async def cleanup(self) -> None:\n        \"\"\"Clean up sandbox if configured.\"\"\"\n        if self.cleanup and self.root_dir.exists():\n            try:\n                import shutil\n                shutil.rmtree(self.root_dir)\n                logger.info(\"Cleaned up sandbox at %s\", self.root_dir)\n            except Exception as e:\n                logger.warning(\"Failed to cleanup sandbox: %s\", e)\n    \n    def __del__(self):\n        \"\"\"Destructor - attempt cleanup if async cleanup wasn't called.\"\"\"\n        if self.cleanup and self.root_dir.exists():\n            try:\n                import shutil\n                shutil.rmtree(self.root_dir)\n            except:\n                pass  # Best effort in destructor\n```\n\n**Key Security Features:**\n1. `_resolve_path()` blocks path traversal attacks\n2. All paths resolved relative to sandbox root\n3. Absolute paths outside sandbox are rejected\n4. Errors don't expose internal path information\n\n**Verification Checklist:**\n- [ ] SandboxBackend class implements required methods\n- [ ] _resolve_path() blocks ../ traversal\n- [ ] _resolve_path() blocks absolute path escapes\n- [ ] read() works for files in sandbox\n- [ ] write() creates files in sandbox\n- [ ] edit() modifies files correctly\n- [ ] ls() lists directory contents\n- [ ] glob() finds files by pattern\n- [ ] grep() searches file contents\n- [ ] execute() runs commands in sandbox cwd\n- [ ] cleanup() removes sandbox directory\n- [ ] All error cases handled gracefully\n- [ ] Tests verify sandbox isolation\n- [ ] Tests ve